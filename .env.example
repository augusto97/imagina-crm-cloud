# Backend (apps/api)
NODE_ENV=development
PORT=3001
DATABASE_URL=postgres://imagina:imagina@localhost:5432/imagina_base
REDIS_URL=redis://localhost:6379
# Sesiones opacas en Redis (STANDALONE.md §5)
SESSION_TTL_SECONDS=2592000
COOKIE_SECURE=false
# Billing webhook (stand-in de Stripe; vacío = deshabilitado)
BILLING_WEBHOOK_SECRET=
# Origen público del SPA — URLs absolutas en emails (magic link del portal)
APP_BASE_URL=http://localhost:5174
# Email (ADR-S11). log = escribe al logger (default); smtp = nodemailer real
MAIL_TRANSPORT=log
MAIL_FROM=Imagina Base <no-reply@imagina.base>
# Sólo si MAIL_TRANSPORT=smtp:
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Pagos (ADR-S12). Cada proveedor se habilita al setear sus credenciales.
# PayPal (USD):
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
# Mercado Pago (COP):
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
