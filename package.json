{
    "name": "imagina-base",
    "private": true,
    "packageManager": "pnpm@10.33.0",
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build",
        "lint": "turbo run lint",
        "typecheck": "turbo run typecheck",
        "test": "turbo run test",
        "infra:up": "docker compose -f docker/docker-compose.yml up -d --wait",
        "infra:down": "docker compose -f docker/docker-compose.yml down",
        "db:generate": "pnpm --filter @imagina-base/api db:generate",
        "db:migrate": "pnpm --filter @imagina-base/api db:migrate"
    },
    "devDependencies": {
        "@eslint/js": "^9.30.0",
        "eslint": "^9.30.0",
        "turbo": "^2.5.4",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.35.0"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "argon2",
            "esbuild",
            "@nestjs/core",
            "cpu-features",
            "ssh2",
            "protobufjs",
            "unrs-resolver"
        ],
        "overrides": {
            "ioredis": "5.11.1"
        }
    }
}
