{
    "name": "@imagina-base/api",
    "version": "0.1.0",
    "private": true,
    "description": "Backend NestJS (Fastify) + Drizzle de Imagina CRM Cloud.",
    "main": "dist/main.js",
    "scripts": {
        "dev": "node --watch -r @swc-node/register src/main.ts",
        "build": "tsc -p tsconfig.build.json && node -e \"require('fs').cpSync('src/db/migrations','dist/db/migrations',{recursive:true})\"",
        "start": "node dist/main.js",
        "lint": "eslint src test",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "test": "vitest run",
        "bench": "vitest run --config vitest.bench.config.ts",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "tsx src/db/migrate.ts",
        "db:seed": "pnpm build && node dist/db/seed.js"
    },
    "dependencies": {
        "@fastify/compress": "^8.3.1",
        "@fastify/cookie": "^11.0.2",
        "@fastify/rate-limit": "^10.3.0",
        "@imagina-base/shared": "workspace:*",
        "@nestjs/common": "^11.1.3",
        "@nestjs/core": "^11.1.3",
        "@nestjs/platform-fastify": "^11.1.3",
        "@nestjs/platform-socket.io": "^11.1.28",
        "@nestjs/websockets": "^11.1.28",
        "@socket.io/redis-adapter": "^8.3.0",
        "argon2": "^0.41.1",
        "bullmq": "^5.79.3",
        "drizzle-orm": "^0.45.2",
        "fastify": "^5.8.5",
        "ioredis": "^5.11.0",
        "nodemailer": "^9.0.3",
        "pg": "^8.16.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2",
        "socket.io": "^4.8.3",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@eslint/js": "^9.30.0",
        "@swc-node/register": "^1.11.1",
        "@swc/core": "^1.15.43",
        "@testcontainers/postgresql": "^11.0.3",
        "@testcontainers/redis": "^11.0.3",
        "@types/node": "^22.15.0",
        "@types/nodemailer": "^8.0.1",
        "@types/pg": "^8.15.4",
        "drizzle-kit": "^0.31.1",
        "eslint": "^9.30.0",
        "tsx": "^4.20.3",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.35.0",
        "vitest": "^3.2.4"
    }
}
