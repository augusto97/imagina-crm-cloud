{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2023"],
        "module": "commonjs",
        "moduleResolution": "node",
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "noImplicitOverride": true,
        "forceConsistentCasingInFileNames": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "declaration": true,
        "sourceMap": true
    }
}
