# ── .env.production — copiá a /opt/imagina-base/.env.production y completá ──
# Lo usan TANTO docker-compose.prod.yml (Postgres/Redis) COMO el API (systemd).
# NO lo commitees con valores reales. Generá secrets con: openssl rand -hex 32

# --- Postgres/Redis (los consume docker-compose.prod.yml) ---
POSTGRES_USER=imagina
POSTGRES_PASSWORD=CAMBIAR_password_fuerte
POSTGRES_DB=imagina_base
REDIS_PASSWORD=CAMBIAR_password_fuerte

# --- API (los consume el proceso NestJS) ---
NODE_ENV=production
PORT=3001
# Deben coincidir con las credenciales de arriba (los env files NO interpolan).
DATABASE_URL=postgres://imagina:CAMBIAR_password_fuerte@127.0.0.1:5432/imagina_base
REDIS_URL=redis://:CAMBIAR_password_fuerte@127.0.0.1:6379
SESSION_TTL_SECONDS=2592000
# Detrás de HTTPS (Caddy) → cookie segura obligatoria.
COOKIE_SECURE=true
# URL pública del SPA (para links absolutos en emails / retorno de pagos).
APP_BASE_URL=https://app.tu-dominio.com

# --- Email (ADR-S11). log = no envía; smtp = real ---
MAIL_TRANSPORT=smtp
MAIL_FROM=Imagina Base <no-reply@tu-dominio.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# --- Pagos (ADR-S12). Vacío = proveedor deshabilitado ---
PAYPAL_ENV=live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# --- Billing webhook stand-in (opcional; vacío = deshabilitado) ---
BILLING_WEBHOOK_SECRET=
